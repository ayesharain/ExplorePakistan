@{
    ViewBag.Title = "Admin Dashboard";
    var destinations = ViewBag.RecentDestinations as List<ExplorePakistan.Models.Destination>;
}

<section class="py-5" style="margin-top:70px;">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-0">Admin Dashboard</h2>
                <p class="text-muted mb-0">Manage your destinations, users, and content.</p>
            </div>
            <a href="@Url.Action("Create", "Admin")" class="btn btn-emerald">
                <i class="fas fa-plus me-1"></i> Add Destination
            </a>
        </div>

        <!-- Stats Cards -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card stat-card border-0 shadow-sm p-3 text-center fade-in">
                    <h2 class="fw-bold mb-0" style="color:#1a7f5a;">@ViewBag.TotalDestinations</h2>
                    <small class="text-muted">Destinations</small>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card border-0 shadow-sm p-3 text-center fade-in">
                    <h2 class="fw-bold mb-0" style="color:#2196f3;">@ViewBag.TotalUsers</h2>
                    <small class="text-muted">Users</small>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card border-0 shadow-sm p-3 text-center fade-in">
                    <h2 class="fw-bold mb-0" style="color:#f0a500;">@ViewBag.TotalReviews</h2>
                    <small class="text-muted">Reviews</small>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card border-0 shadow-sm p-3 text-center fade-in">
                    <h2 class="fw-bold mb-0" style="color:#e91e63;">@ViewBag.TotalMessages</h2>
                    <small class="text-muted">Messages</small>
                </div>
            </div>
        </div>

        <!-- Quick Links -->
        <div class="mb-4">
            <a href="@Url.Action("Destinations", "Admin")" class="btn btn-outline-success me-2">
                <i class="fas fa-list me-1"></i> Manage Destinations
            </a>
            <a href="@Url.Action("Messages", "Admin")" class="btn btn-outline-primary me-2">
                <i class="fas fa-envelope me-1"></i> View Messages
            </a>
        </div>

        <!-- Recent Destinations Table -->
        <div class="card border-0 shadow-sm fade-in">
            <div class="card-body">
                <h5 class="fw-bold mb-3">Recent Destinations</h5>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr><th>Name</th><th>Category</th><th>Province</th><th>Status</th><th>Actions</th></tr>
                        </thead>
                        <tbody>
                            @if (destinations != null)
                            {
                                foreach (var d in destinations)
                                {
                            <tr>
                                <td class="fw-bold">@d.Name</td>
                                <td>@d.Category?.Icon @d.Category?.Name</td>
                                <td>@d.Province</td>
                                <td>
                                    @if (d.IsActive)
                                            {
                                    <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                    <span class="badge bg-warning text-dark">Draft</span>
                                            }
                                </td>
                                <td>
                                    <a href="@Url.Action("Edit", "Admin", new { id = d.Id })" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </td>
                            </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>