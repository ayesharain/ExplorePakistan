@model List<ExplorePakistan.Models.Destination>
@{
    ViewBag.Title = "Manage Destinations";
}

<section class="py-5" style="margin-top:70px;">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">Manage Destinations</h2>
            <a href="@Url.Action("Create", "Admin")" class="btn btn-emerald">
                <i class="fas fa-plus me-1"></i> Add New
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
        <div class="alert alert-success animate__animated animate__fadeInDown">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        </div>
        }

        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Image</th>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Province</th>
                                <th>Featured</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model)
                            {
                            <tr>
                                <td>
                                    <img src="@(d.ImageUrl ?? "https://via.placeholder.com/50")"
                                         style="width:50px;height:50px;object-fit:cover;border-radius:8px;" />
                                </td>
                                <td class="fw-bold">@d.Name</td>
                                <td>@d.Category?.Icon @d.Category?.Name</td>
                                <td>@d.Province</td>
                                <td>
                                    @if (d.IsFeatured)
                                        {
                                    <i class="fas fa-star text-warning"></i>
                                        }
                                </td>
                                <td>
                                    @if (d.IsActive)
                                        {
                                    <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                    <span class="badge bg-warning text-dark">Draft</span>
                                        }
                                </td>
                                <td>
                                    <a href="@Url.Action("Edit", "Admin", new { id = d.Id })"
                                       class="btn btn-sm btn-outline-primary me-1">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                    @using (Html.BeginForm("Delete", "Admin", new { id = d.Id }, FormMethod.Post,
                                            new { style = "display:inline", onsubmit = "return confirm('Are you sure you want to delete this destination?')" }))
                                        {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                        }
                                </td>
                            </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>