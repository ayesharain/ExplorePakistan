@model List<ExplorePakistan.Models.ContactMessage>
@{
    ViewBag.Title = "Messages";
}

<section class="py-5" style="margin-top:70px;">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-0">
                    <i class="fas fa-envelope text-primary me-2"></i>Contact Messages
                </h2>
                <p class="text-muted mb-0">@Model.Count messages received</p>
            </div>
            <a href="@Url.Action("Index", "Admin")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i> Back to Dashboard
            </a>
        </div>

        @if (Model.Any())
        {
            foreach (var msg in Model)
            {
        <div class="card border-0 shadow-sm mb-3 fade-in">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <h6 class="fw-bold mb-0">@msg.Subject</h6>
                        <small class="text-muted">
                            From: <strong>@msg.Name</strong> (@msg.Email)
                        </small>
                    </div>
                    <small class="text-muted">
                        <i class="fas fa-clock me-1"></i>@msg.CreatedAt.ToString("MMM dd, yyyy h:mm tt")
                    </small>
                </div>
                <p class="text-muted mb-0 mt-2">@msg.Message</p>
            </div>
        </div>
            }
        }
        else
        {
        <div class="text-center py-5">
            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
            <h4 class="text-muted">No messages yet</h4>
            <p class="text-muted">Messages from the contact form will appear here.</p>
        </div>
        }
    </div>
</section>