@using Microsoft.AspNet.Identity
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Explore Pakistan</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Poppins', sans-serif;
        }

        body {
            padding-top: 0;
            overflow-x: hidden;
        }

        /* ===== NAVBAR ===== */
        .navbar-custom {
            background: transparent !important;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            padding: 20px 0;
        }

            .navbar-custom.scrolled {
                background: rgba(26, 42, 58, 0.95) !important;
                backdrop-filter: blur(12px);
                padding: 10px 0;
                box-shadow: 0 4px 30px rgba(0,0,0,0.3);
            }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.5rem;
        }

        .nav-link {
            transition: color 0.3s;
        }

            .nav-link:hover {
                color: #f0a500 !important;
            }

        /* ===== HERO SLIDESHOW + KEN BURNS ===== */
        .hero-section {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .hero-slide {
            position: absolute;
            inset: 0;
            background-size: cover;
            background-position: center;
            opacity: 0;
            animation: kenBurns 20s ease infinite;
            transition: opacity 1.5s ease;
        }

            .hero-slide.active {
                opacity: 1;
            }

        @@keyframes kenBurns {
            0% {
                transform: scale(1) translate(0, 0);
            }

            50% {
                transform: scale(1.1) translate(-1%, -1%);
            }

            100% {
                transform: scale(1) translate(0, 0);
            }
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(10,30,50,0.7), rgba(10,30,50,0.4));
            z-index: 1;
        }

        .hero-content {
            position: relative;
            z-index: 2;
            text-align: center;
            color: white;
        }

        /* ===== PARALLAX SECTIONS ===== */
        .parallax-section {
            background-attachment: fixed;
            background-size: cover;
            background-position: center;
            position: relative;
        }

        .parallax-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.6);
        }

        /* ===== SCROLL ANIMATIONS ===== */
        .fade-in {
            opacity: 0;
            transform: translateY(40px);
            transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
        }

            .fade-in.visible {
                opacity: 1;
                transform: translateY(0);
            }

        .slide-left {
            opacity: 0;
            transform: translateX(-40px);
            transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
        }

            .slide-left.visible {
                opacity: 1;
                transform: translateX(0);
            }

        .slide-right {
            opacity: 0;
            transform: translateX(40px);
            transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
        }

            .slide-right.visible {
                opacity: 1;
                transform: translateX(0);
            }

        /* Stagger delays */
        .stagger-1 {
            transition-delay: 0.1s;
        }

        .stagger-2 {
            transition-delay: 0.2s;
        }

        .stagger-3 {
            transition-delay: 0.3s;
        }

        .stagger-4 {
            transition-delay: 0.4s;
        }

        .stagger-5 {
            transition-delay: 0.5s;
        }

        .stagger-6 {
            transition-delay: 0.6s;
        }

        /* ===== CATEGORY CARDS ===== */
        .cat-card {
            border: none;
            border-radius: 20px;
            overflow: hidden;
            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
            cursor: pointer;
            position: relative;
        }

            .cat-card:hover {
                transform: translateY(-10px) scale(1.03);
                box-shadow: 0 20px 50px rgba(0,0,0,0.2);
            }

            .cat-card img {
                transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
                height: 180px;
                object-fit: cover;
                width: 100%;
            }

            .cat-card:hover img {
                transform: scale(1.15);
            }

        .cat-card-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 60%);
            display: flex;
            align-items: flex-end;
            padding: 20px;
            color: white;
        }

        /* ===== DESTINATION CARDS ===== */
        .dest-card {
            border: none;
            border-radius: 20px;
            overflow: hidden;
            position: relative;
            min-height: 320px;
            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
            cursor: pointer;
        }

            .dest-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 24px 60px rgba(0,0,0,0.2);
            }

        .dest-card-bg {
            position: absolute;
            inset: 0;
            background-size: cover;
            background-position: center;
            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .dest-card:hover .dest-card-bg {
            transform: scale(1.08);
        }

        .dest-card-content {
            position: relative;
            z-index: 2;
            height: 100%;
            min-height: 320px;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding: 24px;
            background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);
            color: white;
        }

        /* ===== FILTER BUTTONS ===== */
        .filter-btn {
            padding: 10px 24px;
            border-radius: 30px;
            border: 2px solid #e0e0e0;
            background: white;
            font-weight: 500;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            text-decoration: none;
            color: #333;
            display: inline-block;
        }

            .filter-btn:hover {
                border-color: #1a7f5a;
                color: #1a7f5a;
                transform: translateY(-2px);
            }

            .filter-btn.active {
                background: linear-gradient(135deg, #1a7f5a, #2d9b7a);
                color: white;
                border-color: transparent;
                box-shadow: 0 4px 15px rgba(26,127,90,0.4);
            }

        /* ===== COLORFUL BUTTONS ===== */
        .btn-gradient {
            background: linear-gradient(135deg, #f0a500, #e67e22);
            border: none;
            color: #1a1a2e;
            font-weight: 700;
            padding: 14px 36px;
            border-radius: 12px;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            box-shadow: 0 6px 20px rgba(240,165,0,0.35);
            font-size: 1rem;
        }

            .btn-gradient:hover {
                transform: translateY(-3px) scale(1.02);
                box-shadow: 0 10px 30px rgba(240,165,0,0.5);
                color: #1a1a2e;
            }

        .btn-emerald {
            background: linear-gradient(135deg, #1a7f5a, #2d9b7a);
            border: none;
            color: white;
            font-weight: 600;
            padding: 12px 28px;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(26,127,90,0.3);
            transition: all 0.3s;
        }

            .btn-emerald:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 25px rgba(26,127,90,0.5);
                color: white;
            }

        /* ===== CTA ===== */
        .cta-section {
            background: linear-gradient(-45deg, #1a7f5a, #2d6b9b, #7b2d8b, #c4792d);
            background-size: 400% 400%;
            animation: gradientShift 10s ease infinite;
            border-radius: 28px;
        }

        @@keyframes gradientShift {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        /* ===== STAR RATING ===== */
        .stars {
            color: #f0a500;
        }

        /* ===== FOOTER ===== */
        .footer-custom {
            background: linear-gradient(135deg, #0a1628, #1a2a3e);
        }

        /* ===== RESPONSIVE ===== */
        @@media (max-width: 768px) {
            .hero-section {
                min-height: 80vh;
            }

            .dest-card {
                min-height: 260px;
            }

            .parallax-section {
                background-attachment: scroll;
            }

            .navbar-brand {
                font-size: 1.2rem;
            }
        }

        /* ===== FORM FOCUS ===== */
        .form-control:focus, .form-select:focus {
            border-color: #1a7f5a;
            box-shadow: 0 0 0 0.25rem rgba(26,127,90,0.15);
        }
    </style>
</head>
<body>
    <!-- Sticky Animated Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom fixed-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                🇵🇰 Explore Pakistan
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Home")">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Destination")">Destinations</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Contact")">Contact</a></li>
                    @if (Request.IsAuthenticated)
                    {
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Admin")">Admin</a></li>
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (Request.IsAuthenticated)
                    {
                    <li class="nav-item">
                        <span class="nav-link"><i class="fas fa-user me-1"></i>@User.Identity.GetUserName()</span>
                    </li>
                    <li class="nav-item">
                        @using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { id = "logoutForm" }))
                            {
                        @Html.AntiForgeryToken()
                        <a href="javascript:document.getElementById('logoutForm').submit()" class="nav-link">Logout</a>
                            }
                    </li>
                    }
                    else
                    {
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Login", "Account")">Login</a></li>
                    <li class="nav-item"><a class="btn btn-gradient btn-sm ms-2" href="@Url.Action("Register", "Account")">Sign Up</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>@RenderBody()</main>

    <footer class="footer-custom text-light py-5 mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5 class="fw-bold mb-3">🇵🇰 Explore Pakistan</h5>
                    <p class="text-light opacity-75 small">Discover mountains, beaches, history, culture, adventure, and spiritual sites across Pakistan.</p>
                </div>
                <div class="col-md-2">
                    <h6 class="fw-bold mb-3" style="color:#f0a500">EXPLORE</h6>
                    <a href="@Url.Action("Index", "Destination")" class="d-block text-light opacity-75 small mb-2 text-decoration-none">Destinations</a>
                    <a href="#" class="d-block text-light opacity-75 small mb-2 text-decoration-none">Categories</a>
                    <a href="#" class="d-block text-light opacity-75 small mb-2 text-decoration-none">Top Rated</a>
                </div>
                <div class="col-md-2">
                    <h6 class="fw-bold mb-3" style="color:#f0a500">COMPANY</h6>
                    <a href="#" class="d-block text-light opacity-75 small mb-2 text-decoration-none">About Us</a>
                    <a href="@Url.Action("Index", "Contact")" class="d-block text-light opacity-75 small mb-2 text-decoration-none">Contact</a>
                    <a href="#" class="d-block text-light opacity-75 small mb-2 text-decoration-none">Privacy</a>
                </div>
                <div class="col-md-4">
                    <h6 class="fw-bold mb-3" style="color:#f0a500">CONNECT</h6>
                    <a href="#" class="text-light me-3"><i class="fab fa-facebook fa-lg"></i></a>
                    <a href="#" class="text-light me-3"><i class="fab fa-instagram fa-lg"></i></a>
                    <a href="#" class="text-light me-3"><i class="fab fa-twitter fa-lg"></i></a>
                    <a href="#" class="text-light"><i class="fab fa-youtube fa-lg"></i></a>
                </div>
            </div>
            <hr class="my-4" style="border-color:rgba(255,255,255,0.1)" />
            <p class="text-center text-light opacity-50 small mb-0">&copy; 2026 Explore Pakistan. Made with ❤️ in Pakistan</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // === Sticky Navbar Color Change on Scroll ===
        window.addEventListener('scroll', function () {
            var nav = document.getElementById('mainNav');
            if (window.scrollY > 80) {
                nav.classList.add('scrolled');
            } else {
                nav.classList.remove('scrolled');
            }
        });

        // === Scroll Animations (Fade-in, Slide) ===
        document.addEventListener('DOMContentLoaded', function () {
            var observer = new IntersectionObserver(function (entries) {
                entries.forEach(function (entry) {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    }
                });
            }, { threshold: 0.1 });

            document.querySelectorAll('.fade-in, .slide-left, .slide-right').forEach(function (el) {
                observer.observe(el);
            });
        });

        // === Hero Slideshow ===
        var slideIndex = 0;
        function cycleSlides() {
            var slides = document.querySelectorAll('.hero-slide');
            if (slides.length === 0) return;
            slides.forEach(function (s) { s.classList.remove('active'); });
            slideIndex = (slideIndex + 1) % slides.length;
            slides[slideIndex].classList.add('active');
        }
        setInterval(cycleSlides, 5000);

        // === Category Filter Animation ===
        function filterDestinations(category) {
            document.querySelectorAll('.filter-btn').forEach(function (btn) {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');

            document.querySelectorAll('.filter-item').forEach(function (item) {
                if (category === 'all' || item.dataset.category === category) {
                    item.classList.remove('hidden');
                    item.style.position = 'relative';
                } else {
                    item.classList.add('hidden');
                }
            });
        }
    </script>
    @RenderSection("scripts", required: false)
</body>
</html>