@model ExplorePakistan.Models.LoginViewModel
@{
    ViewBag.Title = "Login";
}

<section class="d-flex align-items-center justify-content-center" style="min-height:100vh;
    background: linear-gradient(135deg, #e8f5e9, #e3f2fd, #f3e5f5);
    padding-top:70px;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card border-0 shadow-lg animate__animated animate__fadeInUp" style="border-radius:20px;">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <h3 class="fw-bold">Welcome Back 👋</h3>
                            <p class="text-muted">Sign in to your Explore Pakistan account</p>
                        </div>

                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
                        {
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-bold">Email Address</label>
                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control form-control-lg", placeholder = "you@example.com" })
                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Password</label>
                            @Html.PasswordFor(m => m.Password, new { @class = "form-control form-control-lg", placeholder = "Enter your password" })
                            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                        </div>
                        <div class="mb-3 form-check">
                            @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input" })
                            <label class="form-check-label">Remember me</label>
                        </div>
                        <button type="submit" class="btn btn-emerald btn-lg w-100">Sign In</button>
                        }

                        <p class="text-center mt-3 small text-muted">
                            Don't have an account?
                            <a href="@Url.Action("Register", "Account")" class="text-success fw-bold">Sign up</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>