@model ExplorePakistan.Models.RegisterViewModel
@{
    ViewBag.Title = "Register";
}

<section class="d-flex align-items-center justify-content-center" style="min-height:100vh;
    background: linear-gradient(135deg, #e8f5e9, #fff8e1, #fce4ec);
    padding-top:70px;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card border-0 shadow-lg animate__animated animate__fadeInUp" style="border-radius:20px;">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <h3 class="fw-bold">Join Us 🌟</h3>
                            <p class="text-muted">Create your Explore Pakistan account</p>
                        </div>

                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        @using (Html.BeginForm("Register", "Account", FormMethod.Post))
                        {
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-bold">Full Name</label>
                            @Html.TextBoxFor(m => m.FullName, new { @class = "form-control form-control-lg", placeholder = "Your full name" })
                            @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger small" })
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Email Address</label>
                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control form-control-lg", placeholder = "you@example.com" })
                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Password</label>
                            @Html.PasswordFor(m => m.Password, new { @class = "form-control form-control-lg", placeholder = "Min 6 characters" })
                            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Confirm Password</label>
                            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control form-control-lg", placeholder = "Re-enter password" })
                            @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small" })
                        </div>
                        <button type="submit" class="btn btn-emerald btn-lg w-100">Create Account</button>
                        }

                        <p class="text-center mt-3 small text-muted">
                            Already have an account?
                            <a href="@Url.Action("Login", "Account")" class="text-success fw-bold">Sign in</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>